{
  "name": "@palindromepay/sdk",
  "version": "2.0.1",
  "description": "TypeScript SDK for PalindromeCryptoEscrow - Secure blockchain escrow with buyer/seller protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "ts-node tests/testCore.ts && ts-node tests/testSecurity.ts",
    "test:core": "ts-node tests/testCore.ts",
    "test:security": "ts-node tests/testSecurity.ts",
    "prepublishOnly": "npm test && npm run build",
    "publish:skip-tests": "npm run build && npm publish --access public --ignore-scripts",
    "version": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "escrow",
    "crypto",
    "ethereum",
    "blockchain",
    "smart-contract",
    "payment",
    "web3",
    "typescript",
    "viem"
  ],
  "author": "Palindrome Pay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/palindrome-finance/escrow-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/palindrome-finance/escrow-sdk/issues"
  },
  "homepage": "https://github.com/palindrome-finance/escrow-sdk#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "commonjs",
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/template": "^7.27.2",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "csstype": "^3.1.3",
    "expect": "^30.2.0",
    "graphql": "^16.11.0",
    "pretty-format": "^30.2.0",
    "react": "^19.2.0",
    "react-window": "^1.8.7",
    "undici-types": "^7.16.0",
    "viem": "^2.38.0"
  },
  "devDependencies": {
    "@apollo/client": "^4.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
