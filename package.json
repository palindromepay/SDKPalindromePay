{
  "name": "@palindromepay/sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK for PalindromePay - Secure blockchain escrow with outcome-bound 2-of-3 multisig and buyer/seller protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "ts-node tests/testCore.ts && ts-node tests/testSecurity.ts",
    "test:core": "ts-node tests/testCore.ts",
    "test:security": "ts-node tests/testSecurity.ts",
    "prepublishOnly": "npm test && npm run build",
    "publish:skip-tests": "npm run build && npm publish --access public --ignore-scripts",
    "version": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "escrow",
    "crypto",
    "ethereum",
    "blockchain",
    "smart-contract",
    "payment",
    "web3",
    "typescript",
    "viem"
  ],
  "author": "Palindrome Pay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/palindromepay/SDKPalindromePay.git"
  },
  "bugs": {
    "url": "https://github.com/palindromepay/SDKPalindromePay/issues"
  },
  "homepage": "https://www.palindromepay.com/sdk",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "commonjs",
  "dependencies": {
    "viem": "^2.38.0"
  },
  "peerDependencies": {
    "@apollo/client": "^3.6.0 || ^4.0.0"
  },
  "devDependencies": {
    "@apollo/client": "^4.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
